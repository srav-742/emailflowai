generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String?
  plan              String             @default("free")
  profileImage      String?            @map("profile_image")
  oauthProvider     String?            @map("oauth_provider")
  firebaseUid       String?            @map("firebase_uid")
  stripeCustomerId  String?            @map("stripe_customer_id")
  accessToken       String?            @map("access_token")
  refreshToken      String?            @map("refresh_token")
  tokenExpiry       DateTime?          @map("token_expiry")
  gmailConnectedAt  DateTime?          @map("gmail_connected_at")
  lastLogin         DateTime?          @map("last_login")
  lastSyncAt        DateTime?          @map("last_sync_at")
  style             Json?
  importantContacts String[]           @default([]) @map("important_contacts")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  actionItems       ActionItem[]
  aiLogs            AILog[]
  aiTraining        AITraining[]
  analyticsDaily    AnalyticsDaily[]
  analyticsEvents   AnalyticsEvent[]
  calendarEvents    CalendarEvent[]
  clientErrorLogs   ClientErrorLog[]
  digests           DailyDigest[]
  digestPreference  DigestPreference?
  emailAccounts     EmailAccount[]
  emails            Email[]
  followUps         FollowUp[]
  oauthTokens       OAuthToken[]
  pushSubscriptions PushSubscription[]
  semanticIndexes   SemanticEmailIndex[]
  memoryNodes       MemoryNode[]
  memoryRelations   MemoryRelation[]
  agentWorkflowApprovals AgentWorkflowApproval[]
  styleProfile      StyleProfile?
  subscription      Subscription?
  threads           Thread[]
  stats             UserStats?

  @@map("users")
}

model StyleProfile {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  tone              String?
  formalityScore    Int      @default(5) @map("formality_score")
  avgSentenceLength Int      @default(15) @map("avg_sentence_length")
  commonOpeners     String[] @map("common_openers")
  commonClosers     String[] @map("common_closers")
  punctuationStyle  String?  @map("punctuation_style")
  vocabularyLevel   String?  @map("vocabulary_level")
  rawProfile        Json?    @map("raw_profile")
  lastLearnedAt     DateTime @default(now()) @map("last_learned_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("style_profiles")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model OAuthToken {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  email        String
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  tokenExpiry  DateTime @map("token_expiry")
  scope        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([tokenExpiry])
  @@map("oauth_tokens")
}

model AITraining {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  emailId      String   @map("email_id")
  originalText String   @map("original_text")
  editedText   String   @map("edited_text")
  tone         String?
  context      String?
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([emailId])
  @@map("ai_training")
}

model Email {
  id               String                   @id @default(uuid())
  userId           String                   @map("user_id")
  accountId        String?                  @map("account_id")
  messageId        String?                  @map("message_id")
  threadId         String?                  @map("thread_id")
  subject          String?
  body             String?
  snippet          String?
  summary          String?
  tasks            Json?
  priority         String                   @default("normal")
  category         String                   @default("uncategorized")
  labels           String[]                 @default([])
  actionRequired   Boolean                  @default(false) @map("action_required")
  sender           String?
  senderName       String?                  @map("sender_name")
  recipients       String[]                 @map("recipients")
  gmailLabelIds    String[]                 @default([]) @map("gmail_label_ids")
  isSent           Boolean                  @default(false) @map("is_sent")
  isSentByUser     Boolean                  @default(false) @map("is_sent_by_user")
  isEditedReply    Boolean                  @default(false) @map("is_edited_reply")
  followUp         Boolean                  @default(false) @map("follow_up")
  followUpAt       DateTime?                @map("follow_up_at")
  receivedAt       DateTime                 @default(now()) @map("received_at")
  isRead           Boolean                  @default(false) @map("is_read")
  isStarred        Boolean                  @default(false) @map("is_starred")
  aiConfidence     Float?                   @map("ai_confidence")
  categorizedAt    DateTime?                @map("categorized_at")
  provider         String                   @default("gmail")
  priorityScore    Float                    @default(0.5) @map("priority_score")
  priorityReason   String?                  @map("priority_reason")
  priorityScoredAt DateTime?                @map("priority_scored_at")
  searchVector     Unsupported("tsvector")? @map("search_vector")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  actionItems      ActionItem[]
  aiLogs           AILog[]
  attachments      Attachment[]
  account          EmailAccount?            @relation(fields: [accountId], references: [id])
  thread           Thread?                  @relation(fields: [threadId], references: [id])
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  followUps        FollowUp[]
  embedding        EmailEmbedding?
  semanticIndex    SemanticEmailIndex?
  agentWorkflowApprovals AgentWorkflowApproval[]

  @@unique([userId, messageId])
  @@index([userId, receivedAt(sort: Desc)])
  @@index([userId, category])
  @@index([userId, receivedAt(sort: Desc), category])
  @@index([userId, priorityScore(sort: Desc)])
  @@index([threadId])
  @@index([accountId])
  @@index([priority])
  @@map("emails")
}

model Attachment {
  id          String   @id @default(uuid())
  emailId     String   @map("email_id")
  filename    String
  contentType String   @map("content_type")
  sizeBytes   Int?     @map("size_bytes")
  storageKey  String   @map("storage_key")
  createdAt   DateTime @default(now()) @map("created_at")
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@map("attachments")
}

model Thread {
  id             String   @id
  userId         String   @map("user_id")
  summary        String?
  priority       String   @default("normal")
  category       String   @default("general")
  actionRequired Boolean  @default(false) @map("action_required")
  company        String?
  role           String?
  deadline       String?
  lastReceivedAt DateTime @map("last_received_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  emails         Email[]
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastReceivedAt])
  @@map("threads")
}

model EmailAccount {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  provider     String       @default("gmail")
  email        String
  displayName  String?      @map("display_name")
  isPrimary    Boolean      @default(false) @map("is_primary")
  color        String?
  syncEnabled  Boolean      @default(true) @map("sync_enabled")
  accessToken  String?      @map("access_token")
  refreshToken String?      @map("refresh_token")
  tokenExpiry  DateTime?    @map("token_expiry")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  lastSyncAt       DateTime?    @map("last_sync_at")
  requiresReconnect Boolean     @default(false) @map("requires_reconnect")
  actionItems      ActionItem[]
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails           Email[]
  followUps        FollowUp[]

  @@unique([provider, email])
  @@index([userId])
  @@map("email_accounts")
}

model UserStats {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  emailsProcessed Int      @default(0) @map("emails_processed")
  aiActions       Int      @default(0) @map("ai_actions")
  timeSaved       Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model AILog {
  id         String   @id @default(uuid())
  emailId    String   @map("email_id")
  userId     String   @map("user_id")
  actionType String   @map("action_type")
  prompt     String?
  response   String?
  model      String?
  createdAt  DateTime @default(now()) @map("created_at")
  email      Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([userId])
  @@index([actionType])
  @@map("ai_logs")
}

model ActionItem {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  accountId   String?       @map("account_id")
  emailId     String        @map("email_id")
  threadId    String?       @map("thread_id")
  title       String
  description String?
  assignee    String?
  dueDate     DateTime?     @map("due_date")
  priority    String        @default("medium")
  status      String        @default("pending")
  extractedAt DateTime      @default(now()) @map("extracted_at")
  completedAt DateTime?     @map("completed_at")
  account     EmailAccount? @relation(fields: [accountId], references: [id])
  email       Email         @relation(fields: [emailId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, dueDate])
  @@index([accountId])
  @@map("action_items")
}

model FollowUp {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  accountId       String?       @map("account_id")
  sentEmailId     String        @map("sent_email_id")
  threadId        String        @map("thread_id")
  recipientEmail  String        @map("recipient_email")
  subject         String
  sentAt          DateTime      @map("sent_at")
  remindAt        DateTime      @map("remind_at")
  replyReceivedAt DateTime?     @map("reply_received_at")
  status          String        @default("waiting")
  snoozedUntil    DateTime?     @map("snoozed_until")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  account         EmailAccount? @relation(fields: [accountId], references: [id])
  email           Email         @relation(fields: [sentEmailId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, remindAt])
  @@index([accountId])
  @@map("follow_ups")
}

model DailyDigest {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  digestDate  DateTime  @map("digest_date")
  scheduledAt DateTime  @map("scheduled_at")
  deliveredAt DateTime? @map("delivered_at")
  content     Json
  emailSent   Boolean   @default(false) @map("email_sent")
  openedAt    DateTime? @map("opened_at")
  status      String    @default("pending")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, digestDate])
  @@map("daily_digests")
}

model DigestPreference {
  id               String  @id @default(uuid())
  userId           String  @unique @map("user_id")
  sendTime         String  @default("07:30") @map("send_time")
  timezone         String  @default("UTC")
  emailEnabled     Boolean @default(true) @map("email_enabled")
  includeActions   Boolean @default(true) @map("include_actions")
  includeFollowups Boolean @default(true) @map("include_followups")
  includeCalendar  Boolean @default(true) @map("include_calendar")
  maxEmails        Int     @default(5) @map("max_emails")
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("digest_preferences")
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique @map("user_id")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  plan                 String    @default("free")
  status               String    @default("active")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  trialEnd             DateTime? @map("trial_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventType String   @map("event_type")
  metadata  Json?    @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType])
  @@index([createdAt])
  @@map("analytics_events")
}

model AnalyticsDaily {
  userId           String   @map("user_id")
  date             DateTime @map("date")
  emailsProcessed  Int      @default(0) @map("emails_processed")
  actionsCompleted Int      @default(0) @map("actions_completed")
  followupsSent    Int      @default(0) @map("followups_sent")
  timeSavedSeconds Int      @default(0) @map("time_saved_seconds")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, date])
  @@index([date])
  @@map("analytics_daily")
}

model CalendarEvent {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  googleEventId String   @map("google_event_id")
  calendarId    String   @map("calendar_id")
  title         String
  description   String?
  startTime     DateTime @map("start_time")
  endTime       DateTime @map("end_time")
  attendees     Json?
  meetingLink   String?  @map("meeting_link")
  linkedEmailId String?  @map("linked_email_id")
  syncedAt      DateTime @default(now()) @map("synced_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, googleEventId])
  @@map("calendar_events")
}

model ClientErrorLog {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  errorMessage  String   @map("error_message")
  errorStack    String?  @map("error_stack")
  componentName String?  @map("component_name")
  pageUrl       String?  @map("page_url")
  browserInfo   Json?    @map("browser_info")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("client_error_logs")
}

model FailedJob {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  queueName String   @map("queue_name")
  jobName   String   @map("job_name")
  payload   Json
  error     String
  attempts  Int
  createdAt DateTime @default(now()) @map("created_at")

  @@index([queueName])
  @@map("failed_jobs")
}

model SemanticEmailIndex {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  emailId        String   @unique @map("email_id")
  contentHash    String   @map("content_hash")
  subjectText    String?  @map("subject_text")
  searchText     String   @map("search_text")
  embedding      Json
  embeddingModel String   @map("embedding_model")
  provider       String   @default("local-hash")
  indexedAt      DateTime @default(now()) @map("indexed_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  email          Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, indexedAt(sort: Desc)])
  @@map("semantic_email_index")
}

model EmailEmbedding {
  id            String   @id @default(uuid())
  emailId       String   @unique @map("email_id")
  subjectVector Json     @map("subject_vector")
  bodyVector    Json     @map("body_vector")
  threadVector  Json     @map("thread_vector")
  createdAt     DateTime @default(now()) @map("created_at")
  email         Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@map("email_embeddings")
}

model MemoryNode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  value     String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, type])
  @@map("memory_nodes")
}

model MemoryRelation {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  sourceId     String   @map("source_id")
  targetId     String   @map("target_id")
  relationType String   @map("relation_type")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, relationType])
  @@map("memory_relations")
}

model AgentWorkflowApproval {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String
  status      String
  explanation String
  payload     Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, status])
  @@map("agent_workflow_approvals")
}

model MemoryNode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String   // Entity name (e.g. "Sarah", "Microsoft", "Q3 Hiring")
  type      String   // Entity type (e.g. "person", "company", "project", "deadline", "commitment")
  metadata  Json?    // Extracted detail (e.g. email reference, description, role)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Graph relationships where this node is the source or target
  sources   MemoryRelation[] @relation("SourceNode")
  targets   MemoryRelation[] @relation("TargetNode")

  @@unique([userId, name, type])
  @@index([userId])
  @@index([type])
  @@map("memory_nodes")
}

model MemoryRelation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  sourceId  String   @map("source_id")
  targetId  String   @map("target_id")
  type      String   // Relationship type (e.g. "works_at", "committed_to", "mentioned_in")
  metadata  Json?    // Optional connection context (e.g. emailId, context snippet)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source    MemoryNode @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)
  target    MemoryNode @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId, targetId, type])
  @@index([userId])
  @@map("memory_relations")
}

model AgentWorkflowApproval {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  emailId     String?  @map("email_id")
  triggerType String   @map("trigger_type") // e.g. "meeting_request", "invoice_overdue"
  title       String   // e.g. "Schedule meeting with Sarah"
  description String?  // AI rationale for the workflow
  status      String   @default("pending") // "pending", "approved", "rejected", "executed"
  actionData  Json     // The raw task instructions (e.g. proposed draft reply, draft calendar event)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     Email?   @relation(fields: [emailId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@map("agent_workflow_approvals")
}
