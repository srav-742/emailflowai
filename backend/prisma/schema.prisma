generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  plan             String    @default("free")
  profileImage     String?   @map("profile_image")
  oauthProvider    String?   @map("oauth_provider")
  firebaseUid      String?   @map("firebase_uid")
  stripeCustomerId String?   @map("stripe_customer_id")
  accessToken      String?   @db.Text @map("access_token")
  refreshToken     String?   @db.Text @map("refresh_token")
  tokenExpiry      DateTime? @map("token_expiry")
  gmailConnectedAt DateTime? @map("gmail_connected_at")
  lastLogin        DateTime? @map("last_login")
  lastSyncAt       DateTime? @map("last_sync_at")
  style            Json?
  importantContacts String[] @default([]) @map("important_contacts")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  emails           Email[]
  threads          Thread[]
  aiLogs           AILog[]
  actionItems      ActionItem[]
  aiTraining       AITraining[]
  emailAccounts    EmailAccount[]
  stats            UserStats?
  followUps        FollowUp[]
  digests          DailyDigest[]
  digestPreference DigestPreference?
  subscription     Subscription?
  analyticsEvents  AnalyticsEvent[]
  analyticsDaily   AnalyticsDaily[]
  calendarEvents   CalendarEvent[]
  oauthTokens      OAuthToken[]
  clientErrorLogs  ClientErrorLog[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model OAuthToken {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  email        String
  accessToken  String   @db.Text @map("access_token")
  refreshToken String   @db.Text @map("refresh_token")
  tokenExpiry  DateTime @map("token_expiry")
  scope        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([tokenExpiry])
  @@map("oauth_tokens")
}

model AITraining {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  emailId      String   @map("email_id")
  originalText String   @db.Text @map("original_text")
  editedText   String   @db.Text @map("edited_text")
  tone         String?
  context      String?
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([emailId])
  @@map("ai_training")
}

model Email {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  accountId      String?   @map("account_id")
  messageId      String?   @map("message_id")
  threadId       String?   @map("thread_id")
  subject        String?
  body           String?   @db.Text
  snippet        String?
  summary        String?   @db.Text
  tasks          Json?
  priority       String    @default("normal")
  category       String    @default("uncategorized")
  labels         String[]  @default([])
  actionRequired Boolean   @default(false) @map("action_required")
  sender         String?
  senderName     String?   @map("sender_name")
  recipients     String[]  @map("recipients")
  gmailLabelIds  String[]  @default([]) @map("gmail_label_ids")
  isSent         Boolean   @default(false) @map("is_sent")
  isSentByUser   Boolean   @default(false) @map("is_sent_by_user")
  isEditedReply  Boolean   @default(false) @map("is_edited_reply")
  followUp       Boolean   @default(false) @map("follow_up")
  followUpAt     DateTime? @map("follow_up_at")
  receivedAt     DateTime  @default(now()) @map("received_at")
  isRead         Boolean   @default(false) @map("is_read")
  isStarred      Boolean   @default(false) @map("is_starred")
  aiConfidence   Float?    @map("ai_confidence")
  categorizedAt  DateTime? @map("categorized_at")
  searchVector   Unsupported("tsvector")? @map("search_vector")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread         Thread?   @relation(fields: [threadId], references: [id], onDelete: SetNull)
  account        EmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  aiLogs         AILog[]
  actionItems    ActionItem[]
  followUps      FollowUp[]

  @@index([userId, receivedAt(sort: Desc)])
  @@index([userId, category])
  @@index([userId, receivedAt(sort: Desc), category])
  @@index([threadId])
  @@index([accountId])
  @@index([priority])
  @@unique([userId, messageId])
  @@map("emails")
}

model Thread {
  id             String    @id
  userId         String    @map("user_id")
  summary        String?   @db.Text
  priority       String    @default("normal")
  category       String    @default("general")
  actionRequired Boolean   @default(false) @map("action_required")
  company        String?
  role           String?
  deadline       String?
  lastReceivedAt DateTime  @map("last_received_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails         Email[]

  @@index([userId, lastReceivedAt])
  @@map("threads")
}

model EmailAccount {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  provider     String
  email        String
  displayName  String?  @map("display_name")
  isPrimary    Boolean  @default(false) @map("is_primary")
  color        String?
  syncEnabled  Boolean  @default(true) @map("sync_enabled")
  accessToken  String?  @db.Text @map("access_token")
  refreshToken String?  @db.Text @map("refresh_token")
  tokenExpiry  DateTime? @map("token_expiry")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  lastSyncAt   DateTime? @map("last_sync_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails       Email[]
  actionItems  ActionItem[]
  followUps    FollowUp[]

  @@index([userId])
  @@unique([provider, email])
  @@map("email_accounts")
}

model UserStats {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  emailsProcessed Int      @default(0) @map("emails_processed")
  aiActions       Int      @default(0) @map("ai_actions")
  timeSaved       Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model AILog {
  id         String   @id @default(uuid())
  emailId    String   @map("email_id")
  userId     String   @map("user_id")
  actionType String   @map("action_type")
  prompt     String?  @db.Text
  response   String?  @db.Text
  model      String?
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([userId])
  @@index([actionType])
  @@map("ai_logs")
}

model ActionItem {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  accountId    String?   @map("account_id")
  emailId      String    @map("email_id")
  threadId     String?   @map("thread_id")
  title        String
  description  String?   @db.Text
  assignee     String?   // me | sender | other
  dueDate      DateTime? @map("due_date")
  priority     String    @default("medium") // high | medium | low
  status       String    @default("pending") // pending | done | dismissed
  extractedAt  DateTime  @default(now()) @map("extracted_at")
  completedAt  DateTime? @map("completed_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        Email     @relation(fields: [emailId], references: [id], onDelete: Cascade)
  account      EmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, status, dueDate])
  @@index([accountId])
  @@map("action_items")
}

model FollowUp {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  accountId       String?   @map("account_id")
  sentEmailId     String    @map("sent_email_id")
  threadId        String    @map("thread_id")
  recipientEmail  String    @map("recipient_email")
  subject         String
  sentAt          DateTime  @map("sent_at")
  remindAt        DateTime  @map("remind_at")
  replyReceivedAt DateTime? @map("reply_received_at")
  status          String    @default("waiting") // waiting | replied | snoozed | dismissed
  snoozedUntil    DateTime? @map("snoozed_until")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email           Email     @relation(fields: [sentEmailId], references: [id], onDelete: Cascade)
  account         EmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, status, remindAt])
  @@index([accountId])
  @@map("follow_ups")
}

model DailyDigest {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  digestDate   DateTime @map("digest_date")
  scheduledAt  DateTime @map("scheduled_at")
  deliveredAt  DateTime? @map("delivered_at")
  content      Json     // { emails[], actions[], followups[] }
  emailSent    Boolean  @default(false) @map("email_sent")
  openedAt     DateTime? @map("opened_at")
  status       String   @default("pending") // pending | sent | failed

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, digestDate])
  @@map("daily_digests")
}

model DigestPreference {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  sendTime         String   @default("07:30") @map("send_time")
  timezone         String   @default("UTC")
  emailEnabled     Boolean  @default(true) @map("email_enabled")
  includeActions   Boolean  @default(true) @map("include_actions")
  includeFollowups Boolean  @default(true) @map("include_followups")
  includeCalendar  Boolean  @default(true) @map("include_calendar")
  maxEmails        Int      @default(5) @map("max_emails")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("digest_preferences")
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique @map("user_id")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  plan                 String    @default("free")
  status               String    @default("active")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  trialEnd             DateTime? @map("trial_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model AnalyticsEvent {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  eventType        String   @map("event_type") // email_processed | action_completed | followup_sent | digest_opened
  metadata         Json?    @map("metadata") // { email_id, time_saved_seconds, category }
  createdAt        DateTime @default(now()) @map("created_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType])
  @@index([createdAt])
  @@map("analytics_events")
}

model AnalyticsDaily {
  userId           String   @map("user_id")
  date             DateTime @map("date") // Day being summarized (midnight)
  emailsProcessed  Int      @default(0) @map("emails_processed")
  actionsCompleted Int      @default(0) @map("actions_completed")
  followupsSent    Int      @default(0) @map("followups_sent")
  timeSavedSeconds Int      @default(0) @map("time_saved_seconds")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, date])
  @@index([date])
  @@map("analytics_daily")
}

model CalendarEvent {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  googleEventId   String   @map("google_event_id")
  calendarId      String   @map("calendar_id")
  title           String
  description     String?  @db.Text
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  attendees       Json?    // Array of { email, name, response_status }
  meetingLink     String?  @map("meeting_link")
  linkedEmailId   String?  @map("linked_email_id")
  syncedAt        DateTime @default(now()) @map("synced_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, googleEventId])
  @@map("calendar_events")
}

model ClientErrorLog {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  errorMessage  String   @map("error_message") @db.Text
  errorStack    String?  @map("error_stack") @db.Text
  componentName String?  @map("component_name")
  pageUrl       String?  @map("page_url")
  browserInfo   Json?    @map("browser_info")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("client_error_logs")
}
