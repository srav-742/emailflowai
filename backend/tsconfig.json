{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/server.ts",
    "src/config/env.ts",
    "src/data/**/*.ts",
    "src/runtime/**/*.ts",
    "src/types.ts",
    "src/utils/router.ts"
  ]
}
