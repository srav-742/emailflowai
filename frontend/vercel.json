{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://emailflowai.onrender.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://emailflowai.onrender.com/auth/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "https://emailflowai.onrender.com/api",
      "VITE_SOCKET_URL": "https://emailflowai.onrender.com"
    }
  },
  "env": {
    "VITE_API_URL": "https://emailflowai.onrender.com/api",
    "VITE_SOCKET_URL": "https://emailflowai.onrender.com"
  }
}

