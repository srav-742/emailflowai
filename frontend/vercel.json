{
  "version": 2,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://emailflowai-api.onrender.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://emailflowai-api.onrender.com/auth/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://emailflowai-api.onrender.com"
  }
}
