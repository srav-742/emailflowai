{
  "name": "emailflow-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "preview:frontend": "npm --prefix frontend run preview",
    "dev:backend": "npm --prefix backend start",
    "start:backend": "npm --prefix backend start",
    "db:generate": "npm --prefix backend run prisma:generate",
    "start": "npm run start:backend",
    "build": "npm run build:frontend && npm run db:generate",
    "check": "node --check backend/server.js && node --check backend/src/controllers/emailController.js && node --check backend/src/controllers/authController.js && node --check backend/src/routes/authRoutes.js && node --check backend/src/routes/emailRoutes.js",
    "lint": "npm --prefix frontend run lint",
    "test:backend": "npm --prefix backend test",
    "test:frontend": "npm --prefix frontend test",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "vite": "^6.0.1"
  }
}
