{
  "name": "emailflow-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "preview:frontend": "npm --prefix frontend run preview",
    "dev:backend": "npm --prefix backend run dev",
    "start:backend": "npm --prefix backend run start",
    "db:generate": "npm --prefix backend run prisma:generate",
    "build": "npm run build:frontend",
    "check": "node --check backend/src/server.js && node --check backend/src/controllers/emailController.js && node --check backend/src/controllers/authController.js && node --check backend/src/routes/authRoutes.js && node --check backend/src/routes/emailRoutes.js",
    "lint": "npm --prefix frontend run lint"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^4.5.5",
    "lucide-react": "^0.356.0",
    "googleapis": "^134.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "vite": "^8.0.3"
  }
}
