{
  "buildCommand": "cd frontend && npm install && npx vite build --config vite.build.mjs",
  "outputDirectory": "frontend/dist",
  "installCommand": "echo 'skip'",
  "build": {
    "env": {
      "VITE_API_URL": "https://emailflowai.onrender.com/api",
      "VITE_SOCKET_URL": "https://emailflowai.onrender.com"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
